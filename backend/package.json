{
  "name": "block-vote-backend",
  "version": "0.1.0",
  "private": true,
  "description": "Contract-first backend starter for the blockchain voting TCC project.",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "start": "node dist/server.js",
    "build": "tsc -p tsconfig.json",
    "lint:openapi": "redocly lint openapi/openapi.yaml",
    "preview:docs": "redocly preview-docs openapi/openapi.yaml",
    "generate:frontend-types": "openapi-typescript openapi/openapi.yaml -o ../frontend/src/shared/lib/api/generated/schema.ts"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^5.1.0",
    "helmet": "^8.1.0",
    "swagger-ui-express": "^5.0.1",
    "yaml": "^2.6.1"
  },
  "devDependencies": {
    "@redocly/cli": "^1.34.5",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.3",
    "@types/node": "^24.0.0",
    "@types/swagger-ui-express": "^4.1.8",
    "openapi-typescript": "^7.10.1",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3"
  }
}
